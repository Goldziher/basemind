/target
/.basemind
# poly (polylint) local cache
/.polylint
*.swp

# Release build artifacts
/dist
# Binary the plugin MCP launcher (scripts/mcp-launch.sh) downloads on demand
/bin/
/pip-package/build
/pip-package/dist
/pip-package/basemind.egg-info
/pip-package-hermes/build
/pip-package-hermes/dist
/pip-package-hermes/basemind_hermes_plugin.egg-info
/npm-package/bin/*
!/npm-package/bin/basemind.js
/npm-package/node_modules
/npm-package/*.tgz
/opencode-plugin/node_modules
/opencode-plugin/*.tgz


# Python bytecode
__pycache__/
*.pyc


# Codex plugin: tracked manifests that live under otherwise-ignored paths.
# `.mcp.json` (line above) and `.agents/` (ai-rulez block) are ignored broadly,
# but these two files are hand-authored, version-controlled Codex plugin surfaces
# and MUST ship — re-include them explicitly.
!.codex-plugin/.mcp.json
!.agents/
.agents/*
!.agents/plugins/
!.agents/plugins/marketplace.json

poly.local.toml

# ai-rulez harness outputs left over from a wider `presets` set than the current one
# (config.toml now generates only "claude" + "codex", which the managed block below covers).
# Every file here carries the "AI-RULEZ :: GENERATED FILE" header — it is derived from
# .ai-rulez/, regenerable, and machine-local, so it stays out of git like the rest of the
# generated harness surface. Kept on disk because these are the live rule files for whichever
# editors a contributor happens to run.
.cline/
.clinerules/
.continue/
.cursor/
.gemini/
.junie/
.opencode/
.windsurf/
GEMINI.md
.github/copilot-instructions.md
.github/agents/
.github/commands/
.github/skills/

# BEGIN ai-rulez (DO NOT EDIT - managed by ai-rulez)
.ai-rulez/.generated-manifest.json
.claude/
.codex/
.mcp.json
AGENTS.md
CLAUDE.md
# END ai-rulez
